# Configuration for eBay Scraper
# Use your local Chrome installation to leverage your existing login session.

# Path to your Chrome executable. 
# Typical Windows path: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Path to your Chrome User Data directory to use your existing login session.
# Typical Windows path: C:\Users\<YourUsername>\AppData\Local\Google\Chrome\User Data
# Note: You can create a dedicated 'eBayScraper' profile to avoid conflicts.
USER_DATA_DIR=C:\Users\mazha\AppData\Local\Google\Chrome\User Data

# The specific Profile directory name (e.g., 'Default' or 'Profile 1')
CHROME_PROFILE_NAME=Default

# Optional: Output file format (json or csv)
OUTPUT_FORMAT=json

# AI Analysis Configuration
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Online MySQL Database Connection String
# Example: mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
DATABASE_URL=
